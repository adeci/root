{
  "data": {
    "aws_ami": {
      "nixos": {
        "filter": [
          {
            "name": "name",
            "values": [
              "determinate/nixos/epoch-1/*"
            ]
          },
          {
            "name": "architecture",
            "values": [
              "x86_64"
            ]
          }
        ],
        "most_recent": true,
        "owners": [
          "535002876703"
        ]
      }
    },
    "http": {
      "my_ip": {
        "url": "https://ipv4.icanhazip.com"
      }
    }
  },
  "output": {
    "claudia_id": {
      "description": "Claudia instance ID",
      "value": "${aws_instance.claudia.id}"
    },
    "claudia_ip": {
      "description": "Public IP of Claudia",
      "value": "${aws_eip.claudia_eip.public_ip}"
    },
    "claudia_ssh": {
      "description": "SSH command for Claudia",
      "value": "ssh -i ~/.ssh/claudia root@${aws_eip.claudia_eip.public_ip}"
    }
  },
  "provider": {
    "aws": {
      "region": "us-east-1"
    },
    "http": {}
  },
  "resource": {
    "aws_eip": {
      "claudia_eip": {
        "domain": "vpc",
        "tags": {
          "ManagedBy": "Terraform",
          "Name": "claudia-eip"
        }
      }
    },
    "aws_eip_association": {
      "claudia_eip_assoc": {
        "allocation_id": "${aws_eip.claudia_eip.id}",
        "instance_id": "${aws_instance.claudia.id}"
      }
    },
    "aws_instance": {
      "claudia": {
        "ami": "${data.aws_ami.nixos.id}",
        "instance_type": "t2.small",
        "key_name": "${aws_key_pair.claudia_key.key_name}",
        "root_block_device": {
          "encrypted": true,
          "volume_size": 128,
          "volume_type": "gp3"
        },
        "tags": {
          "ManagedBy": "Terraform",
          "Name": "claudia"
        },
        "vpc_security_group_ids": [
          "${aws_security_group.claudia_sg.id}"
        ]
      }
    },
    "aws_key_pair": {
      "claudia_key": {
        "key_name": "claudia-ssh-key",
        "public_key": "${file(\"~/.ssh/claudia.pub\")}"
      }
    },
    "aws_security_group": {
      "claudia_sg": {
        "description": "Security group for Claudia server",
        "egress": [
          {
            "cidr_blocks": [
              "0.0.0.0/0"
            ],
            "description": "All outbound traffic",
            "from_port": 0,
            "ipv6_cidr_blocks": [],
            "prefix_list_ids": [],
            "protocol": "-1",
            "security_groups": [],
            "self": false,
            "to_port": 0
          }
        ],
        "ingress": [
          {
            "cidr_blocks": [
              "${chomp(data.http.my_ip.response_body)}/32"
            ],
            "description": "SSH from current IP",
            "from_port": 22,
            "ipv6_cidr_blocks": [],
            "prefix_list_ids": [],
            "protocol": "tcp",
            "security_groups": [],
            "self": false,
            "to_port": 22
          },
          {
            "cidr_blocks": [
              "0.0.0.0/0"
            ],
            "description": "Minecraft server",
            "from_port": 25565,
            "ipv6_cidr_blocks": [],
            "prefix_list_ids": [],
            "protocol": "tcp",
            "security_groups": [],
            "self": false,
            "to_port": 25569
          },
          {
            "cidr_blocks": [
              "0.0.0.0/0"
            ],
            "description": "Simple Voice Chat",
            "from_port": 24454,
            "ipv6_cidr_blocks": [],
            "prefix_list_ids": [],
            "protocol": "udp",
            "security_groups": [],
            "self": false,
            "to_port": 24458
          }
        ],
        "name": "claudia-sg",
        "tags": {
          "Name": "claudia-security-group"
        }
      }
    }
  },
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "registry.opentofu.org/hashicorp/aws",
        "version": "~> 5.0"
      },
      "http": {
        "source": "registry.opentofu.org/hashicorp/http",
        "version": "~> 3.0"
      }
    },
    "required_version": ">= 1.0.0"
  }
}
