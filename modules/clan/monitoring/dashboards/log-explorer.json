{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["adeci", "logs", "loki"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Log Explorer",
  "uid": "adeci-logs",
  "version": 1,
  "weekStart": "",
  "templating": {
    "list": [
      {
        "name": "machine",
        "label": "Machine",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": {
          "label": "machine",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "",
          "type": 1
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": {
          "label": "service_name",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "{machine=~\"$machine\"}",
          "type": 1
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "query": "emerg,alert,crit,err,warning,notice,info,debug",
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "emerg", "value": "emerg" },
          { "selected": false, "text": "alert", "value": "alert" },
          { "selected": false, "text": "crit", "value": "crit" },
          { "selected": false, "text": "err", "value": "err" },
          { "selected": false, "text": "warning", "value": "warning" },
          { "selected": false, "text": "notice", "value": "notice" },
          { "selected": false, "text": "info", "value": "info" },
          { "selected": false, "text": "debug", "value": "debug" }
        ],
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log volume (lines/sec)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (machine) (rate({machine=~\"$machine\", service_name=~\"$service\", level=~\"$level\"}[1m]))",
          "legendFormat": "{{machine}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "logs" } },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "right",
          "displayMode": "table",
          "calcs": ["mean", "max"]
        }
      },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 7 }
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Noisiest machines (last hour)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by (machine) (count_over_time({machine=~\"$machine\", service_name=~\"$service\", level=~\"$level\"}[$__range])))",
          "legendFormat": "{{machine}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": {
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true
      },
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 9 }
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Noisiest services (last hour)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by (service_name) (count_over_time({machine=~\"$machine\", service_name=~\"$service\", level=~\"$level\"}[$__range])))",
          "legendFormat": "{{service_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": {
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true
      },
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 9 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Warnings/errors per machine",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (machine) (rate({machine=~\"$machine\", service_name=~\"$service\", level=~\"warning|err|crit|alert|emerg\"}[1m]))",
          "legendFormat": "{{machine}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "logs" } },
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 7 }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Recent warnings/errors",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{machine=~\"$machine\", service_name=~\"$service\", level=~\"warning|err|crit|alert|emerg\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 10 }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Live log stream",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{machine=~\"$machine\", service_name=~\"$service\", level=~\"$level\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 15 }
    }
  ]
}
