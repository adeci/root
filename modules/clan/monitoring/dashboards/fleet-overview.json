{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["adeci", "fleet", "infrastructure"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Fleet Overview",
  "uid": "adeci-fleet",
  "version": 1,
  "weekStart": "",
  "templating": {
    "list": [
      {
        "name": "machine",
        "label": "Machine",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": {
          "query": "label_values(node_uname_info, machine)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Machine status",
      "description": "Green = metrics within the last 2 minutes. Red/missing = stale.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(time() - max by (machine) (timestamp(node_uname_info{machine=~\"$machine\"}))) < 120",
          "legendFormat": "{{machine}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "STALE", "color": "red" },
                "1": { "text": "OK", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU usage (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (1 - avg by (machine) (rate(node_cpu_seconds_total{mode=\"idle\",machine=~\"$machine\"}[1m])))",
          "legendFormat": "{{machine}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "right",
          "displayMode": "table",
          "calcs": ["mean", "max"]
        }
      },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Memory usage (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{machine=~\"$machine\"} / node_memory_MemTotal_bytes{machine=~\"$machine\"}))",
          "legendFormat": "{{machine}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "right",
          "displayMode": "table",
          "calcs": ["mean", "max"]
        }
      },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Load (1m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_load1{machine=~\"$machine\"}",
          "legendFormat": "{{machine}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory pressure (full, seconds per second)",
      "description": "PSI full pressure — stall time per second across the system.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_pressure_memory_stalled_seconds_total{machine=~\"$machine\"}[1m])",
          "legendFormat": "{{machine}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 } },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 }
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Disk usage by mount",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (1 - node_filesystem_avail_bytes{machine=~\"$machine\",fstype!~\"tmpfs|fuse.lxcfs|nsfs|overlay|squashfs|ramfs|devtmpfs\"} / node_filesystem_size_bytes{machine=~\"$machine\",fstype!~\"tmpfs|fuse.lxcfs|nsfs|overlay|squashfs|ramfs|devtmpfs\"})",
          "legendFormat": "{{machine}} {{mountpoint}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true
      },
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 10 }
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Inode usage by mount",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (1 - node_filesystem_files_free{machine=~\"$machine\",fstype!~\"tmpfs|fuse.lxcfs|nsfs|overlay|squashfs|ramfs|devtmpfs\"} / node_filesystem_files{machine=~\"$machine\",fstype!~\"tmpfs|fuse.lxcfs|nsfs|overlay|squashfs|ramfs|devtmpfs\"})",
          "legendFormat": "{{machine}} {{mountpoint}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true
      },
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 10 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Network bytes in",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (machine) (rate(node_network_receive_bytes_total{machine=~\"$machine\",device!~\"lo|docker.*|veth.*|br-.*\"}[1m]))",
          "legendFormat": "{{machine}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 8 }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Network bytes out",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (machine) (rate(node_network_transmit_bytes_total{machine=~\"$machine\",device!~\"lo|docker.*|veth.*|br-.*\"}[1m]))",
          "legendFormat": "{{machine}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "gridPos": { "x": 12, "y": 29, "w": 12, "h": 8 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Network errors + drops",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (machine) (rate(node_network_receive_errs_total{machine=~\"$machine\"}[5m]) + rate(node_network_receive_drop_total{machine=~\"$machine\"}[5m]) + rate(node_network_transmit_errs_total{machine=~\"$machine\"}[5m]) + rate(node_network_transmit_drop_total{machine=~\"$machine\"}[5m]))",
          "legendFormat": "{{machine}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "x": 0, "y": 37, "w": 12, "h": 8 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Disk I/O",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (machine) (rate(node_disk_read_bytes_total{machine=~\"$machine\"}[1m]))",
          "legendFormat": "{{machine}} read",
          "refId": "A"
        },
        {
          "expr": "sum by (machine) (rate(node_disk_written_bytes_total{machine=~\"$machine\"}[1m]))",
          "legendFormat": "{{machine}} write",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "gridPos": { "x": 12, "y": 37, "w": 12, "h": 8 }
    },
    {
      "id": 12,
      "type": "table",
      "title": "Failed systemd units",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_systemd_unit_state{machine=~\"$machine\",state=\"failed\"} == 1",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "Value": true,
              "type": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "machine": "Machine",
              "name": "Unit",
              "state": "State"
            }
          }
        }
      ],
      "gridPos": { "x": 0, "y": 45, "w": 12, "h": 8 }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Temperatures (°C, max per host)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (machine) (node_hwmon_temp_celsius{machine=~\"$machine\"})",
          "legendFormat": "{{machine}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "gridPos": { "x": 12, "y": 45, "w": 12, "h": 8 }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Uptime",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{machine=~\"$machine\"}",
          "legendFormat": "{{machine}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 3600 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "gridPos": { "x": 0, "y": 53, "w": 12, "h": 5 }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Alloy remote_write failure rate (samples/s)",
      "description": "Non-zero means agent push is failing.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (machine) (rate(prometheus_remote_write_samples_failed_total{machine=~\"$machine\"}[5m]))",
          "legendFormat": "{{machine}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "gridPos": { "x": 12, "y": 53, "w": 12, "h": 5 }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Recently rebooted (<1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(time() - node_boot_time_seconds{machine=~\"$machine\"}) < 3600",
          "legendFormat": "{{machine}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "stable", "color": "green" },
                "1": { "text": "recent boot", "color": "yellow" }
              }
            }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "gridPos": { "x": 0, "y": 58, "w": 24, "h": 4 }
    }
  ]
}
